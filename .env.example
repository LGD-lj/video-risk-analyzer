# ============================================
# 视频风险点分析系统 — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================

# ---------- 基础服务配置 ----------
HOST=127.0.0.1
PORT=8000
DATA_DIR=data/jobs
MAX_UPLOAD_SIZE_MB=2000
CLEANUP_HOURS=24

# ---------- 视频抽帧间隔（秒）----------
FRAME_INTERVAL_SECONDS=5

# ---------- 风险去重间隔（秒）----------
DEDUP_INTERVAL_SECONDS=30

# ---------- 最大/最小风险点数量 ----------
MAX_RISK_POINTS=10
MIN_RISK_POINTS=5

# ---------- 视觉模型（用于图片风险识别）----------
# provider: openai（默认，支持 OpenAI / DeepSeek / 其他兼容 API）
VISION_PROVIDER=openai
VISION_API_KEY=sk-your-openai-api-key-here
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o

# ---------- DeepSeek 文本模型（用于润色描述、生成报告）----------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
