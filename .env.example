# ============================================
# 视频风险点分析系统 — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================

# ---------- 基础服务配置 ----------
HOST=127.0.0.1
PORT=8000
DATA_DIR=data/jobs
MAX_UPLOAD_SIZE_MB=2000
CLEANUP_HOURS=24
FAILED_JOB_RETENTION_HOURS=1

# ---------- 分析模式：full(正式) | quick(快速测试) ----------
ANALYSIS_MODE=full
QUICK_FRAME_INTERVAL=15
QUICK_MAX_FRAMES=40

# ---------- 召回优先模式（开启后风险判定更宽松）----------
RISK_RECALL_MODE=true

# ---------- 视频抽帧间隔（秒）----------
FRAME_INTERVAL_SECONDS=5

# ---------- 候选池 ----------
MIN_RISK_SCORE=40
MAX_CANDIDATE_POOL=60

# ---------- 风险去重 ----------
DEDUP_INTERVAL_SECONDS=30
MIN_GAP_SECONDS=20

# ---------- 风险点数量 ----------
MAX_RISK_POINTS=12
MIN_RISK_POINTS=3

# ---------- 视觉模型（用于图片风险识别）----------
# 默认使用阿里云百炼 DashScope（兼容 OpenAI 接口格式）
VISION_PROVIDER=dashscope
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-plus

# ---------- DeepSeek 文本模型（用于润色描述、生成报告）----------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
